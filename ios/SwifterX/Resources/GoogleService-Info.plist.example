<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  ╔══════════════════════════════════════════════════════════════╗
  ║  DO NOT commit the real GoogleService-Info.plist             ║
  ║                                                              ║
  ║  To set up:                                                  ║
  ║  1. Go to https://console.firebase.google.com                ║
  ║  2. Open project: swifterx-e7f15                             ║
  ║  3. Project Settings → Your apps → iOS → Download plist      ║
  ║  4. Save it as: ios/SwifterX/Resources/GoogleService-Info.plist ║
  ╚══════════════════════════════════════════════════════════════╝
-->
<plist version="1.0">
<dict>
    <key>CLIENT_ID</key>
    <string>YOUR_CLIENT_ID.apps.googleusercontent.com</string>
    <key>REVERSED_CLIENT_ID</key>
    <string>com.googleusercontent.apps.YOUR_CLIENT_ID</string>
    <key>API_KEY</key>
    <string>YOUR_API_KEY</string>
    <key>GCM_SENDER_ID</key>
    <string>YOUR_GCM_SENDER_ID</string>
    <key>PLIST_VERSION</key>
    <string>1</string>
    <key>BUNDLE_ID</key>
    <string>com.swifterx.app</string>
    <key>PROJECT_ID</key>
    <string>swifterx-e7f15</string>
    <key>STORAGE_BUCKET</key>
    <string>swifterx-e7f15.firebasestorage.app</string>
    <key>IS_ADS_ENABLED</key>
    <false/>
    <key>IS_ANALYTICS_ENABLED</key>
    <false/>
    <key>IS_APPINVITE_ENABLED</key>
    <true/>
    <key>IS_GCM_ENABLED</key>
    <true/>
    <key>IS_SIGNIN_ENABLED</key>
    <true/>
    <key>GOOGLE_APP_ID</key>
    <string>1:YOUR_GCM_SENDER_ID:ios:YOUR_MOBILESDK_APP_ID</string>
</dict>
</plist>
