rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Provider avatar — authenticated clients only; owner writes JPEG up to 5 MiB.
    match /provider_profiles/{userId}/profile.jpg {
      // Public read: customer UIs load `photoURL` via AsyncImage (download URL token also grants access).
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType == 'image/jpeg';
    }

    // Customer account avatar — same constraints as provider profile photo.
    match /user_profiles/{userId}/profile.jpg {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType == 'image/jpeg';
    }
  }
}
