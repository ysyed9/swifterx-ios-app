default_platform(:ios)

# ─── Config ───────────────────────────────────────────────────────────────────

WORKSPACE  = "ios/SwifterX/SwifterX.xcodeproj"
SCHEME     = "SwifterX"
BUNDLE_ID  = "com.swifterx.app"
TEAM_ID    = "Z855T78S6X"
OUTPUT_DIR = "build"

# ─── Helpers ──────────────────────────────────────────────────────────────────

def app_store_api_key
  app_store_connect_api_key(
    key_id:        ENV["APP_STORE_CONNECT_API_KEY_ID"],
    issuer_id:     ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
    key_content:   ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
    is_key_content_base64: true,
    duration:      1200,
    in_house:      false
  )
end

# ─── Platform ─────────────────────────────────────────────────────────────────

platform :ios do

  # ── Increment build number ──────────────────────────────────────────────────
  desc "Bump build number using App Store Connect latest"
  lane :bump_build do
    api_key = app_store_api_key
    latest  = latest_testflight_build_number(
      api_key:    api_key,
      app_identifier: BUNDLE_ID
    )
    increment_build_number(
      build_number:   (latest + 1).to_s,
      xcodeproj:      "ios/SwifterX/SwifterX.xcodeproj"
    )
  end

  # ── Tests ───────────────────────────────────────────────────────────────────
  desc "Run unit tests (SwifterXTests target)"
  lane :tests do
    run_tests(
      project:     "ios/SwifterX/SwifterX.xcodeproj",
      scheme:      "SwifterXTests",
      device:      "iPhone 16",
      clean:       true,
      output_directory: "fastlane/test_output",
      output_files:     "junit.xml"
    )
  end

  # ── Build (archive for distribution) ────────────────────────────────────────
  desc "Build and archive for TestFlight / App Store"
  lane :build_release do
    increment_build_number(xcodeproj: "ios/SwifterX/SwifterX.xcodeproj")
    build_app(
      project:                 "ios/SwifterX/SwifterX.xcodeproj",
      scheme:                  SCHEME,
      configuration:           "Release",
      export_method:           "app-store",
      output_directory:        OUTPUT_DIR,
      output_name:             "SwifterX.ipa",
      include_bitcode:         false,
      export_options: {
        teamID:               TEAM_ID,
        uploadBitcode:        false,
        compileBitcode:       false,
        provisioningProfiles: {
          BUNDLE_ID => "SwifterX App Store"
        }
      }
    )
  end

  # ── TestFlight ───────────────────────────────────────────────────────────────
  desc "Build and push to TestFlight"
  lane :beta do
    api_key = app_store_api_key
    bump_build
    build_release
    upload_to_testflight(
      api_key:           api_key,
      ipa:               "#{OUTPUT_DIR}/SwifterX.ipa",
      skip_waiting_for_build_processing: true,
      changelog:         changelog_from_git_commits(
        commits_count:   10,
        pretty:          "• %s"
      )
    )
    slack_notification("New TestFlight build uploaded 🚀") if ENV["SLACK_URL"]
  end

  # ── App Store ────────────────────────────────────────────────────────────────
  desc "Submit to App Store for review"
  lane :release do
    api_key = app_store_api_key
    bump_build
    build_release
    upload_to_app_store(
      api_key:                          api_key,
      ipa:                              "#{OUTPUT_DIR}/SwifterX.ipa",
      metadata_path:                    "fastlane/metadata",
      screenshots_path:                 "fastlane/screenshots",
      skip_screenshots:                 false,
      skip_metadata:                    false,
      submit_for_review:                false,   # flip to true when ready
      automatic_release:                false,
      force:                            true,
      precheck_include_in_app_purchases: false
    )
  end

  # ── Screenshots ──────────────────────────────────────────────────────────────
  desc "Capture App Store screenshots on all required device sizes"
  lane :screenshots do
    capture_screenshots(
      project:        "ios/SwifterX/SwifterX.xcodeproj",
      scheme:         "SwifterX",
      output_directory: "fastlane/screenshots",
      clear_previous_screenshots: true,
      devices: [
        "iPhone 16 Pro Max",
        "iPhone 16",
        "iPhone SE (3rd generation)",
        "iPad Pro 13-inch (M4)"
      ],
      languages: ["en-US"]
    )
    frame_screenshots(white: true)
  end

  # ── Sync certs (optional — use match for team codesigning) ───────────────────
  desc "Sync App Store certificates via match"
  lane :certs do
    match(
      type:           "appstore",
      app_identifier: BUNDLE_ID,
      readonly:       true
    )
  end

  # ── Helpers ──────────────────────────────────────────────────────────────────

  def slack_notification(msg)
    slack(message: msg, slack_url: ENV["SLACK_URL"]) if ENV["SLACK_URL"]
  end

  # Notify on error
  error do |lane, exception|
    slack_notification("Lane #{lane} failed: #{exception.message}") if ENV["SLACK_URL"]
  end

end
