# =============================
# SwifterX iOS — .gitignore
# =============================

# ----- Xcode -----
build/
DerivedData/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.xccheckout
*.moved-aside
*.xcuserstate
*.xcscmblueprint
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# ----- Swift Package Manager -----
.build/
.swiftpm/
ios/SwifterX/SwifterX.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/

# ----- CocoaPods (if ever used) -----
Pods/
Podfile.lock

# ----- Firebase / Google — NEVER commit these -----
**/GoogleService-Info.plist
**/google-services.json

# ----- Environment & Secrets -----
.env
.env.*
*.secret
secrets.xcconfig
ios/SwifterX/Config/Secrets.xcconfig
Config/Secrets.swift
**/Secrets.swift

# ----- macOS -----
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ----- Firebase Functions -----
firebase/functions/node_modules/
firebase/functions/.env

# ----- Editor -----
.vscode/
.idea/
*.swp
*.swo

# =============================
# IMPORTANT — Secrets setup
# =============================
# GoogleService-Info.plist is gitignored (never commit).
#   1. Firebase Console → Project settings → Your iOS app → Download GoogleService-Info.plist
#   2. Save as: ios/SwifterX/Resources/GoogleService-Info.plist
#   See Resources/GoogleService-Info.plist.example for shape of the file.
#
# Stripe publishable key (not committed):
#   1. cp ios/SwifterX/Config/Secrets.xcconfig.example ios/SwifterX/Config/Secrets.xcconfig
#   2. Set STRIPE_PUBLISHABLE_KEY in Secrets.xcconfig (merged via Config/Shared.xcconfig)
